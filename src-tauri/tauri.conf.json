{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Code 一键安装程序",
  "version": "1.2.4",
  "identifier": "com.claude.code.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Claude Code 一键安装程序",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "decorations": false,
        "minWidth": 960,
        "minHeight": 640,
        "theme": "Light",
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
